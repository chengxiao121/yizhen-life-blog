---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于我">
  <div class="about">
    <div class="about-avatar">
      <img src="/avatar.jpg" alt="头像" />
    </div>
    <h1>关于我</h1>
    <div class="about-content prose">
      <p>你好，欢迎来到「一帧.life」。</p>
      <p>我叫吴承晓，一名大三学生，热爱并沉迷于打羽毛球，也在断断续续学习知识，准备后面找工作。</p>
      <p>这个博客是我的小小天地，记录技术学习的思考，平常的生活点滴，生活中的所见所感。</p>
      <p>世界那么大，我先溜达溜达。</p>
    </div>
  </div>
</BaseLayout>

<style>
  .about {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }
  .about-avatar {
    margin-bottom: 1.2rem;
  }
  .about-avatar img {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--border-light);
    box-shadow: var(--shadow);
  }
  .about h1 {
    margin-bottom: 1.5rem;
    font-size: 1.6rem;
  }
  .about-content {
    text-align: left;
  }
</style>
