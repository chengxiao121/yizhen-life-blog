---
import TagList from './TagList.astro';

interface Props {
  date: string;
  photos?: string[];
  tags?: string[];
}

const { date, photos = [], tags = [] } = Astro.props;

const dateOnly = date.split(' ')[0];
const timeOnly = date.includes(' ') ? date.split(' ')[1] : '';
---

<div class="moment-card">
  <div class="moment-dot"></div>
  <div class="moment-body">
    <time class="moment-date">
      {dateOnly}
      {timeOnly && <span class="moment-time">{timeOnly}</span>}
    </time>
    <div class="moment-content">
      <slot />
    </div>
    {photos.length > 0 && (
      <div class="moment-photos">
        {photos.map((src) => (
          <img src={src} alt="" loading="lazy" />
        ))}
      </div>
    )}
    {tags.length > 0 && (
      <div class="moment-tags">
        <TagList tags={tags} />
      </div>
    )}
  </div>
</div>

<style>
  .moment-card {
    display: flex;
    gap: 1rem;
    padding: 0 0 1.8rem;
    position: relative;
  }
  .moment-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    margin-top: 0.45rem;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .moment-dot::after {
    content: '';
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: calc(100% + 1.8rem);
    background: var(--border);
  }
  .moment-card:last-child .moment-dot::after {
    display: none;
  }
  .moment-body {
    flex: 1;
    min-width: 0;
  }
  .moment-date {
    font-size: 0.78rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.3rem;
  }
  .moment-time {
    margin-left: 0.4rem;
  }
  .moment-content {
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .moment-content :global(p) {
    margin-bottom: 0;
  }
  .moment-photos {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.6rem;
    flex-wrap: wrap;
  }
  .moment-photos img {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--border-light);
  }
  .moment-tags {
    margin-top: 0.5rem;
  }
</style>
