---
interface Props {
  id: string;
  path: string;
  title?: string;
  date: string;
  width: number;
  height: number;
}

const { id, path, title, date, width, height } = Astro.props;
---

<div
  class="photo-card"
  data-id={id}
  data-src={path}
  data-width={width}
  data-height={height}
  data-title={title}
  data-date={date}
>
  <img
    src={path}
    alt={title || '照片'}
    loading="lazy"
    width={width}
    height={height}
    onload="this.classList.add('loaded')"
    onerror="this.classList.add('error'); this.parentElement.querySelector('.photo-error').style.display='flex'"
  />
  <div class="photo-error" style="display:none">
    <span>图片加载失败</span>
  </div>
</div>
